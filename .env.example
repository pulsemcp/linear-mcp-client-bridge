# ---- Required secrets ----

# Anthropic API key — the brain. https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Linear personal API key — how the bridge reads and writes comments.
# Create one at: Linear → Settings → Security & access → Personal API keys.
# It will look like: lin_api_xxxxxxxxxxxxxxxx
LINEAR_API_TOKEN=lin_api_...


# ---- Optional tuning (sensible defaults shown) ----

# Seconds between polls of the Linear API.
# POLL_INTERVAL_SECONDS=20

# Which Claude model the agent runs on.
# AGENT_MODEL=claude-opus-4-8

# Claude Code permission mode. "bypassPermissions" lets the agent act without
# a human approving each tool call (required for unattended operation). The
# stricter modes assume an interactive approver and will stall a daemon — to
# constrain the agent, scope its tools below instead.
# Read the README "Security" section before changing this.
# AGENT_PERMISSION_MODE=bypassPermissions

# Tool scoping to bound the prompt-injection blast radius (comma-separated).
# AGENT_ALLOWED_TOOLS is an allowlist (only these tools are usable when set);
# AGENT_DISALLOWED_TOOLS is a blocklist applied on top. Both unset = full
# toolset. Example: keep Linear/gateway access but block local mutation.
# AGENT_ALLOWED_TOOLS=mcp__linear__*,mcp__gateway__*,Read
# AGENT_DISALLOWED_TOOLS=Bash,Write,Edit

# Restrict the bridge to specific Linear teams by key (comma-separated).
# Leave empty to respond to comments on every team the token can see.
# LINEAR_TEAM_KEYS=ENG,OPS

# Where to persist the session id + poll cursor (inside the container).
# STATE_DIR=/data
